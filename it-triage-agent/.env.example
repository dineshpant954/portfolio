# Groq API (free tier - get key at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Supabase (free tier - create project at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Slack (create app at api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your_signing_secret

# n8n auth
N8N_USER=admin
N8N_PASSWORD=admin

# n8n webhook URL generation (local defaults)
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678
# For Slack/public webhooks set to your tunnel URL, e.g. https://abc123.trycloudflare.com/
WEBHOOK_URL=http://localhost:5678/

# Cloudflare Tunnel (optional, named tunnel mode)
# Set only when using docker-compose.tunnel.token.yml
CLOUDFLARED_TUNNEL_TOKEN=
